}

// PromptFileManager.js
class PromptFileManager {
  constructor() {
    this.prompts = new Map();
    this.logs = [];
  }

  createPrompt(name, content) {
    this.prompts.set(name, { content, validated: false });
    this.validatePrompt(name);
    this.log(`Prompt ${name} created and validated.`);
  }

  validatePrompt(name) {
    const prompt = this.prompts.get(name);
    prompt.validated = true;
  }

  log(message) {
    this.logs.push({ timestamp: new Date().toISOString(), message });
  }

  getPrompts() {
    return { prompts: Object.fromEntries(this.prompts), logs: this.logs };
  }
}

// InstructionManager.js
class InstructionManager {
  constructor() {
    this.instructions = new Map();
    this.logs = [];
  }

  addInstruction(category, details) {
    this.instructions.set(category, details);
    this.log(`Instruction added for ${category}.`);
  }

  log(message) {
    this.logs.push({ timestamp: new Date().toISOString(), message });
  }

  getInstructions() {
    return { instructions: Object.fromEntries(this.instructions), logs: this.logs };
  }
}

// ToolSetManager.js
class ToolSetManager {
  constructor() {
    this.toolSets = new Map();
    this.logs = [];
  }

  addToolSet(name, tools) {
    this.toolSets.set(name, { tools, active: true });
    this.log(`Tool set ${name} added and activated.`);
  }

  log(message) {
    this.logs.push({ timestamp: new Date().toISOString(), message });
  }

  getToolSets() {
    return { toolSets: Object.fromEntries(this.toolSets), logs: this.logs };
  }
}

// ModeManager.js
class ModeManager {
  constructor() {
    this.modes = new Map();
    this.logs = [];
  }

  activateMode(name, config) {
    this.modes.set(name, { config, active: true });
    this.log(`Mode ${name} activated.`);
  }

  log(message) {
    this.logs.push({ timestamp: new Date().toISOString(), message });
  }

  getModes() {
    return { modes: Object.fromEntries(this.modes), logs: this.logs };
  }
}

// MCPServerManager.js
class MCPServerManager {
  constructor() {
    this.servers = new Map();
    this.logs = [];
  }

  configureServer(name, config) {
    this.servers.set(name, { config, active: true });
    this.log(`MCP server ${name} configured and activated.`);
  }

  log(message) {
    this.logs.push({ timestamp: new Date().toISOString(), message });
  }

  getServers() {
    return { servers: Object.fromEntries(this.servers), logs: this.logs };
  }
}

